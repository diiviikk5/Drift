{
  "name": "drift",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.5.2",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "corepack pnpm --dir apps/desktop localdev",
    "build": "corepack pnpm --dir apps/desktop build",
    "desktop:setup": "node scripts/setup.js && node apps/desktop/scripts/prepare.js",
    "tauri:dev": "npm run desktop:setup && corepack pnpm --dir apps/desktop tauri dev",
    "tauri:build": "npm run desktop:setup && corepack pnpm --dir apps/desktop tauri build",
    "typecheck": "corepack pnpm exec tsc -b",
    "lint": "corepack pnpm exec biome lint",
    "format": "corepack pnpm exec biome check --write"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "typescript": "^5.8.3"
  }
}
